generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique @db.VarChar(50)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at")
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]

  @@map("users")
}

model Account {
  id           Int           @id @default(autoincrement())
  userId       Int           @map("user_id")
  name         String        @db.VarChar(50)
  type         String        @db.VarChar(20) // cash, bank, credit
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@map("accounts")
}

model Category {
  id        Int           @id @default(autoincrement())
  userId    Int?          @map("user_id") // null = 系统预设
  name      String        @db.VarChar(30)
  icon      String        @db.VarChar(50)
  color     String        @db.VarChar(7) // HEX 颜色值
  isPreset  Boolean       @default(false) @map("is_preset")
  createdAt DateTime      @default(now()) @map("created_at")
  user      User?         @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@map("categories")
}

model Transaction {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  accountId  Int      @map("account_id")
  categoryId Int      @map("category_id")
  type       String   @db.VarChar(10) // income, expense
  amount     Decimal  @db.Decimal(12, 2)
  note       String?  @db.VarChar(200)
  transDate  DateTime @map("trans_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id])
  account    Account  @relation(fields: [accountId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([userId, transDate(sort: Desc)])
  @@index([userId, categoryId])
  @@index([userId, type])
  @@index([accountId])
  @@map("transactions")
}
