# ⚠️ 注意：所有值不要使用引号包裹！引号会被视为值的一部分导致解析失败
# 数据库连接（开发环境默认使用 5433 端口避免与本地 PostgreSQL 冲突）
DATABASE_URL=postgresql://purebook:purebook123@localhost:5433/purebook

# Redis 连接（开发环境默认使用 6380 端口避免与本地 Redis 冲突）
REDIS_URL=redis://localhost:6380

# JWT 密钥（生产环境请更换为随机字符串）
JWT_SECRET=your-jwt-secret-change-in-production

# 应用配置
NEXT_PUBLIC_APP_NAME=PureBook
