# ============================================================
# PureBook - Docker 生产环境变量（容器内部通信）
#
# ⚠️ 注意：
#   1. 所有值不要使用引号包裹！引号会被视为值的一部分
#   2. 此文件中 host 使用 Docker 服务名（postgres/redis），不是 localhost
#   3. 复制此文件为 .env.production 并修改 JWT_SECRET
#   4. .env.production 不会被提交到 Git
# ============================================================

# 数据库连接（容器内通过服务名 postgres 通信，端口是容器内部 5432）
DATABASE_URL=postgresql://purebook:purebook123@postgres:5432/purebook

# Redis 连接（容器内通过服务名 redis 通信，端口是容器内部 6379）
REDIS_URL=redis://redis:6379

# JWT 密钥（⚠️ 生产环境务必更换为随机字符串！）
# 生成方法: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# 应用名称
NEXT_PUBLIC_APP_NAME=PureBook
